# Supabase — use Project URL + anon/public OR publishable key (sb_publishable_...)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Optional frontend metadata used by local scripts/checklists.
VITE_SUPABASE_PROJECT_REF=your-project-ref

# OneSignal Web Push (frontend — Netlify env vars)
# REQUIRED for native push notifications on Android PWA / web.
VITE_ONESIGNAL_APP_ID=your-onesignal-app-id
VITE_ONESIGNAL_SAFARI_WEB_ID=your-safari-web-id

# Test push script (scripts/test-onesignal-push.mjs — local only, never commit secrets)
# TEST_LOGIN_EMAIL=user@example.com
# TEST_LOGIN_PASSWORD=your-test-password

# OneSignal setup (manual):
# 1. OneSignal Dashboard → Create Web app TrabaGE
# 2. Site URL https://trabage.org · Allowed origins include localhost:5173
# 3. Copy App ID → VITE_ONESIGNAL_APP_ID (.env.local + Netlify Production)
# 4. REST API Key → Supabase secret ONESIGNAL_REST_API_KEY only (never Netlify)
# 5. Service worker: public/OneSignalSDKWorker.js (verify at /OneSignalSDKWorker.js)
# 6. Deploy send_push edge function with ONESIGNAL_* secrets
# 7. See docs/PUSH_ONESIGNAL.md for Android PWA verification steps

# Sentry
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project

# App
VITE_APP_URL=http://localhost:5173
# Production (Netlify → Environment variables → Production):
#   VITE_APP_URL=https://trabage.org
#   VITE_APP_ENV=production
#   VITE_SUPABASE_URL=...
#   VITE_SUPABASE_ANON_KEY=...
#   VITE_ONESIGNAL_APP_ID=...
#   VITE_ONESIGNAL_SAFARI_WEB_ID=...   (optional)
#   VITE_SENTRY_DSN=...
VITE_APP_ENV=development

# Google OAuth (configure in Supabase Dashboard → Authentication → Providers → Google)
# Also add these redirect URLs in Google Cloud Console → OAuth client → Authorized redirect URIs:
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# And in Supabase → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:5173/auth/callback
#   http://localhost:5173/auth/confirm
#   https://trabage.org/auth/callback
#   https://trabage.org/auth/confirm
#   https://www.trabage.org/auth/callback
#   https://www.trabage.org/auth/confirm

# Supabase Edge Functions (server-side secrets — Supabase Dashboard → Edge Functions → Secrets)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ONESIGNAL_APP_ID=your-onesignal-app-id
# ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key
# APP_URL=https://trabage.org                     # used by send_push for click URLs
# TRABAGE_ALLOWED_ORIGIN=https://trabage.org
#
# Resend (optional for auth verification; welcome emails still use Resend):
#   RESEND_API_KEY=re_xxxxxxxx
#   RESEND_AUTH_FROM_EMAIL=noreply@trabage.org
#   RESEND_WELCOME_FROM_EMAIL=welcome@trabage.org
#   RESEND_FROM_NAME=TrabaGE
#   SEND_EMAIL_HOOK_SECRET="v1,whsec_<generated-in-dashboard>"
#
# Supabase SMTP fallback for auth verification when RESEND_API_KEY is absent:
#   SMTP_HOST=smtp.example.com
#   SMTP_PORT=587
#   SMTP_USER=your-smtp-user
#   SMTP_PASS=your-smtp-password
#   SMTP_FROM_EMAIL=noreply@trabage.org
#   SMTP_FROM_NAME=TrabaGE
#   (Use the same values as Supabase Dashboard → Authentication → SMTP)
#
# Auth emails (Supabase Dashboard → Authentication → Hooks → Send Email):
#   Type: HTTPS
#   URL: https://<project-ref>.supabase.co/functions/v1/send_auth_email
#   Generate Secret → copy to SEND_EMAIL_HOOK_SECRET above
#   Deploy with: supabase functions deploy send_auth_email --no-verify-jwt
#
# Welcome email (send_welcome_email Edge Function — backend only, no frontend trigger):
#   APP_URL=https://trabage.org              # CTA links in welcome emails
#   WELCOME_WEBHOOK_SECRET=your-random-secret
#
# Supabase Dashboard setup:
#   1. Edge Functions → Secrets: RESEND_API_KEY, RESEND_AUTH_FROM_EMAIL, RESEND_WELCOME_FROM_EMAIL, RESEND_FROM_NAME, SEND_EMAIL_HOOK_SECRET, WELCOME_WEBHOOK_SECRET, ONESIGNAL_APP_ID, ONESIGNAL_REST_API_KEY
#   2. Authentication → Hooks → Send Email → send_auth_email URL + secret
#   3. Database → Webhooks → INSERT on public.welcome_email_outbox
#      URL: https://<project-ref>.supabase.co/functions/v1/send_welcome_email
#      HTTP Headers: x-welcome-webhook-secret = <WELCOME_WEBHOOK_SECRET>
#      Authorization: Bearer <SUPABASE_SERVICE_ROLE_KEY>
#
# Deploy:
#   supabase db push
#   supabase functions deploy send_auth_email --no-verify-jwt
#   supabase functions deploy send_welcome_email
#   supabase functions deploy send_push
#   supabase functions deploy match_job_recommendations
#   supabase functions deploy process_matching_recalc
# See PRODUCTION_LAUNCH_CHECKLIST.md for the full go-live gate.
# Matching recalc worker (cron / internal only — never expose to the browser):
#   MATCHING_RECALC_SECRET=your-random-secret
#   Invoke with either:
#     Authorization: Bearer <SUPABASE_SERVICE_ROLE_KEY>
#     or Authorization: Bearer <MATCHING_RECALC_SECRET>
#     or x-matching-recalc-secret: <MATCHING_RECALC_SECRET>

# Local scripts only — never commit real values.
# SUPABASE_DB_PASSWORD=your-database-password
# TEST_LOGIN_EMAIL=user@example.com
# TEST_LOGIN_PASSWORD=local-test-password
#
# Supabase local OAuth config (supabase/config.toml uses env(...) placeholders):
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=your-google-client-id
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=your-google-client-secret
